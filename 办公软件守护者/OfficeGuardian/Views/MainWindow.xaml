<Window x:Class="OfficeGuardian.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="OfficeGuardian - WPS 运行状态监控"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Window.Resources>
        <Style TargetType="Border" x:Key="CardBorder">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Opacity="0.08" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricValue">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#666"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="22" FontWeight="Bold" VerticalAlignment="Center">
                    🛡️ OfficeGuardian
                </TextBlock>
                <TextBlock Grid.Column="1" FontSize="14" Foreground="#666"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           Text="{Binding StatusText}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Background="#E8F5E9" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                        <TextBlock FontSize="12" Foreground="#2E7D32">
                            告警: <Run FontWeight="Bold" Text="{Binding WarningCount}"/>
                        </TextBlock>
                    </Border>
                    <TextBlock FontSize="12" Foreground="#999" VerticalAlignment="Center"
                               Text="{Binding LastScanTime, StringFormat=上一次扫描: {0}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="8,0">
                    <TextBlock Style="{StaticResource MetricLabel}">💾 WPS 内存</TextBlock>
                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#1976D2"
                               Text="{Binding WpsMemory}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0">
                    <TextBlock Style="{StaticResource MetricLabel}">⚡ CPU 占用</TextBlock>
                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#E65100"
                               Text="{Binding WpsCpu}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="8,0">
                    <TextBlock Style="{StaticResource MetricLabel}">🧵 线程数</TextBlock>
                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#2E7D32"
                               Text="{Binding WpsThreads}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="8,0">
                    <TextBlock Style="{StaticResource MetricLabel}">🔧 句柄数</TextBlock>
                    <TextBlock Style="{StaticResource MetricValue}" Foreground="#6A1B9A"
                               Text="{Binding WpsHandles}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="14" FontWeight="SemiBold" Foreground="#1976D2">
                        内存趋势 (MB)
                    </TextBlock>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding MemorySeries}"
                                         XAxes="{Binding MemoryAxis}" Margin="0,8"/>
                    <TextBlock Grid.Row="2" FontSize="11" Foreground="#888"
                               Text="{Binding MemoryTrendDescription}"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="14" FontWeight="SemiBold" Foreground="#E65100">
                        CPU 趋势 (%)
                    </TextBlock>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding CpuSeries}"
                                         XAxes="{Binding CpuAxis}" Margin="0,8"/>
                    <TextBlock Grid.Row="2" FontSize="11" Foreground="#888"
                               Text="{Binding CpuTrendDescription}"/>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="14" FontWeight="SemiBold" Foreground="#2E7D32">
                        线程趋势
                    </TextBlock>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding ThreadSeries}"
                                         XAxes="{Binding ThreadAxis}" Margin="0,8"/>
                    <TextBlock Grid.Row="2" FontSize="11" Foreground="#888"
                               Text="{Binding ThreadTrendDescription}"/>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                    Style="{StaticResource CardBorder}" Margin="8,4,4,4">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,12">
                            📋 操作面板
                        </TextBlock>

                        <Border Background="#F5F5F5" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8">
                                    📊 每日报告
                                </TextBlock>
                                <Button Content="📄 生成今日报告"
                                        Command="{Binding GenerateReportCommand}"
                                        Background="#1976D2" Foreground="White"
                                        Padding="12,8" BorderThickness="0"
                                        Cursor="Hand" Height="36"/>
                                <TextBlock FontSize="11" Foreground="#666" Margin="0,8,0,0"
                                           Text="{Binding ReportResult}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFF3E0" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8">
                                    🤖 AI 分析
                                </TextBlock>
                                <Button Content="🔍 Analyze Report"
                                        Command="{Binding ExportAiCommand}"
                                        Background="#E65100" Foreground="White"
                                        Padding="12,8" BorderThickness="0"
                                        Cursor="Hand" Height="36"/>
                                <TextBlock FontSize="11" Foreground="#BF360C" Margin="0,8,0,0"
                                           Text="{Binding AiAnalysisResult}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFEBEE" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#C62828">
                                    ⚠️ 最近告警
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding RecentWarnings}" MaxHeight="400">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="4"
                                                    Padding="8" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <TextBlock FontWeight="Bold" FontSize="12" Foreground="#C62828"
                                                               Text="{Binding WarningType}"/>
                                                    <TextBlock FontSize="11" Foreground="#666"
                                                               Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"/>
                                                    <TextBlock FontSize="11" Text="{Binding Message}"
                                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
